From 7c8b30b03b053280534e2e0a78c7953a1a96c8c7 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Mon, 20 Jul 2026 12:15:12 +0200
Subject: [PATCH] Align EMK site with dark automotive identity

---
 assets/emk-theme.css       |  64 +++++++++++++++++++++----------------
 assets/hero-road-dark.webp | Bin 0 -> 49582 bytes
 plattform.html             |   7 ++--
 3 files changed, 40 insertions(+), 31 deletions(-)
 create mode 100644 assets/hero-road-dark.webp

diff --git a/assets/emk-theme.css b/assets/emk-theme.css
index 9bd2ed9..0589dfa 100644
--- a/assets/emk-theme.css
+++ b/assets/emk-theme.css
@@ -1,28 +1,28 @@
 /* ==========================================================
    EMK Sverige AB – Globalt tema
-   Färgpalett: marinblå / klarblå / ljus blågrå
+   Färgpalett: grafitsvart / varmvit / diskret EMK-guld
    ========================================================== */
 
 :root {
   /* Ytor */
-  --brand-bg:        #f3f7fb;
-  --brand-surface:   #ffffff;
-  --brand-elev:      #eaf2f8;
+  --brand-bg:        #090a0b;
+  --brand-surface:   #121315;
+  --brand-elev:      #191b1e;
 
   /* Text */
-  --brand-text:      #102b46;
-  --brand-muted:     #5e7184;
+  --brand-text:      #f4f4f1;
+  --brand-muted:     #b9bdc1;
 
   /* Brand */
-  --brand-accent:    #0878a5;
-  --brand-accent-dark:#075a7d;
-  --brand-contrast:  #ffffff;
-  --brand-tint:      #dff1f7;
+  --brand-accent:    #f0f0ed;
+  --brand-accent-dark:#d6d7d5;
+  --brand-contrast:  #111214;
+  --brand-tint:      #222427;
   --brand-gold:      #d4af37;
   --brand-link:      var(--brand-accent);
 
   /* Linjer & radius */
-  --brand-border:    #cfdee9;
+  --brand-border:    #2b2e32;
   --brand-radius:    16px;
 
   /* Layout */
@@ -68,7 +68,7 @@ body {
 
 /* Liten elevation som tilläggsklass – påverkar inte paletten */
 .elev {
-  box-shadow:0 16px 38px rgba(16,43,70,.10);
+  box-shadow:0 18px 42px rgba(0,0,0,.28);
 }
 
 .textcell {
@@ -121,7 +121,7 @@ hr { border:0; border-top:1px solid var(--brand-border); }
   background:linear-gradient(135deg,var(--brand-accent),var(--brand-accent-dark));
   color:var(--brand-contrast);
   border-color:var(--brand-accent);
-  box-shadow:0 8px 20px rgba(8,120,165,.22);
+  box-shadow:0 8px 20px rgba(0,0,0,.24);
 }
 
 /* Stöd både .btn-outline och .btn.ghost */
@@ -144,11 +144,11 @@ hr { border:0; border-top:1px solid var(--brand-border); }
 
 header {
   position:sticky; top:0; z-index:50;
-  background:#0c2842;
+  background:#090a0b;
   border-bottom:1px solid rgba(255,255,255,.12);
 }
 
-.topbar { background:#0c2842; border-bottom:1px solid rgba(255,255,255,.12); }
+.topbar { background:#090a0b; border-bottom:1px solid rgba(255,255,255,.12); }
 .topbar .wrap { display:flex; align-items:center; justify-content:space-between; }
 
 .logo { display:flex; align-items:center; gap:10px; text-decoration:none; color:var(--brand-text); font-weight:800; }
@@ -156,7 +156,7 @@ header {
 
 .nav { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
 .nav a {
-  color:#e9f4fa;
+  color:#eceeeb;
   text-decoration:none;
   padding:10px 11px;
   border-radius:10px;
@@ -216,11 +216,18 @@ header {
 /* Bakgrund och typkänsla */
 .hero-bg{
   background:
-    radial-gradient(900px 440px at 5% -15%, rgba(20,162,207,.42), transparent 68%),
-    radial-gradient(700px 420px at 95% 5%, rgba(8,120,165,.26), transparent 70%),
-    linear-gradient(135deg,#0b2239 0%,#103c5c 58%,#0b304b 100%);
+    radial-gradient(900px 440px at 5% -15%, rgba(255,255,255,.08), transparent 68%),
+    linear-gradient(135deg,#0a0b0d 0%,#141619 100%);
   color:#ffffff;
 }
+.hero.hero-bg{
+  background-image:
+    linear-gradient(90deg,rgba(4,5,6,.88) 0%,rgba(5,6,7,.56) 48%,rgba(4,5,6,.78) 100%),
+    url('/assets/hero-road-dark.webp');
+  background-size:cover;
+  background-position:center;
+  border-bottom:1px solid rgba(255,255,255,.1);
+}
 .hero-bg h1,
 .hero-bg h2,
 .hero-bg h3,
@@ -243,7 +250,7 @@ header {
 .hero-underline{
   text-decoration:underline;
   text-decoration-thickness:4px;
-  text-decoration-color:#55c4e7;
+  text-decoration-color:var(--brand-gold);
   text-underline-offset:6px;
 }
 
@@ -272,7 +279,7 @@ header {
 /* Glow-dekor bakom kort */
 .soft-glow{
   position:absolute; inset:-8px; border-radius:24px;
-  background:#2ab3df; opacity:.22; filter:blur(22px);
+  background:#ffffff; opacity:.08; filter:blur(24px);
 }
 
 /* ==========================================================
@@ -299,8 +306,9 @@ header {
   display:inline-block;
   padding:6px 10px;
   border-radius:999px;
-  background:linear-gradient(135deg,#1598c7,#086f99);
-  color:#ffffff;
+  background:linear-gradient(135deg,#323438,#222427);
+  color:#f4f4f1;
+  border:1px solid rgba(255,255,255,.12);
   font-weight:700;
   font-size:.8rem;
 }
@@ -310,16 +318,16 @@ header {
    ========================================================== */
 
 .trust-section {
-  background:linear-gradient(180deg,#e7f1f7 0%,#f3f7fb 100%);
-  border-top:1px solid #cfdee9;
-  border-bottom:1px solid #cfdee9;
+  background:linear-gradient(180deg,#111315 0%,#090a0b 100%);
+  border-top:1px solid #2b2e32;
+  border-bottom:1px solid #2b2e32;
 }
 .rating-number {
   font-size:clamp(3rem,7vw,5rem);
   line-height:1;
   font-weight:850;
   letter-spacing:-.05em;
-  color:#0c2842;
+  color:#f4f4f1;
 }
 .rating-stars {
   color:var(--brand-gold);
@@ -328,7 +336,7 @@ header {
 }
 .quote-card {
   position:relative;
-  border-top:4px solid var(--brand-accent);
+  border-top:4px solid var(--brand-gold);
 }
 .quote-card::before {
   content:'“';
