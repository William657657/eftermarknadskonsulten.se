 /* ==========================================================
    EMK Sverige AB – Globalt tema
-   Färgpalett: guld / beige / ljus varm bakgrund
+   Färgpalett: marinblå / klarblå / ljus blågrå
    ========================================================== */
 
 :root {
   /* Ytor */
-  --brand-bg:        #FAF7EF;   /* varm ljus bakgrund (låst) */
