+/* ==========================================================
+   Förtroende / kundomdömen
+   ========================================================== */
+
+.trust-section {
+  background:linear-gradient(180deg,#e7f1f7 0%,#f3f7fb 100%);
+  border-top:1px solid #cfdee9;
+  border-bottom:1px solid #cfdee9;
+}
+.rating-number {
+  font-size:clamp(3rem,7vw,5rem);
+  line-height:1;
+  font-weight:850;
+  letter-spacing:-.05em;
+  color:#0c2842;
+}
+.rating-stars {
+  color:var(--brand-gold);
+  font-size:1.45rem;
+  letter-spacing:.12em;
+}
+.quote-card {
+  position:relative;
+  border-top:4px solid var(--brand-accent);
+}
+.quote-card::before {
+  content:'“';
+  position:absolute;
+  right:22px;
+  top:4px;
+  font-size:4.5rem;
+  line-height:1;
+  color:var(--brand-tint);
+  font-family:Georgia,serif;
+}
+
