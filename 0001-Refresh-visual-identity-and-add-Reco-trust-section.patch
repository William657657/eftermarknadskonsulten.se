   text-decoration:underline;
   text-decoration-thickness:4px;
-  text-decoration-color:var(--brand-accent);
+  text-decoration-color:#55c4e7;
   text-underline-offset:6px;
 }
 
 /* Lead och listor */
-.lead   { max-width:60ch; color:var(--brand-text); opacity:.88; }
+.lead   { max-width:60ch; color:inherit; opacity:.9; }
 .bullets{ max-width:66ch; }
 
 /* Badge/chip */
@@ -242,11 +262,17 @@ header {
   font-size:.8rem;
   letter-spacing:.02em;
 }
+.hero-bg .chip{
+  background:rgba(255,255,255,.12);
+  color:#ffffff;
+  border:1px solid rgba(255,255,255,.2);
+  backdrop-filter:blur(8px);
+}
 
 /* Glow-dekor bakom kort */
 .soft-glow{
   position:absolute; inset:-8px; border-radius:24px;
-  background:var(--brand-accent); opacity:.18; filter:blur(18px);
+  background:#2ab3df; opacity:.22; filter:blur(22px);
 }
 
 /* ==========================================================
@@ -273,12 +299,48 @@ header {
   display:inline-block;
   padding:6px 10px;
   border-radius:999px;
-  background:linear-gradient(90deg,var(--brand-accent),#f3d37a);
-  color:#1f2937;
+  background:linear-gradient(135deg,#1598c7,#086f99);
+  color:#ffffff;
   font-weight:700;
   font-size:.8rem;
